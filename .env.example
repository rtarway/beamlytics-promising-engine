PORT=3000
LOG_LEVEL=info
SOURCING_STRATEGY=BALANCED
SLA_STRICTNESS=SOFT
MAX_SEARCH_RADIUS_MILES=2000

# Service URLs (leave empty to use mocks)
INVENTORY_SERVICE_URL=http://inventory-service:3000
RATE_SHOPPER_SERVICE_URL=http://rate-shopper:3000
RETENTION_SERVICE_URL=http://retention-service:3000

# HTTP hardening (optional)
JSON_BODY_LIMIT=1mb
# Max requests / IP / window (15 min) for /api
RATE_LIMIT_MAX=300

# Future: mTLS or shared secrets for downstream calls to inventory / rate / retention.
# For local Docker Compose, override Postgres in a root .env (not committed) — see docker-compose env vars.
